FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /agent

COPY agent/processor.py /agent/
COPY daemon/config.py /agent/config.py
COPY daemon/action_processor.py /agent/

RUN chmod +x /agent/processor.py

# No Ollama, no network, no extra dependencies
# All inference and actions are handled by the daemon

CMD ["python", "/agent/processor.py"]
