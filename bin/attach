#!/bin/bash
# Send input to HAL9000 agent via the operator inbox.
# The host daemon reads inbox from ./state/inbox/ on the host.
# Usage: ./bin/attach "Your message"
set -euo pipefail
cd "$(dirname "$0")"/..

if [ $# -eq 0 ]; then
    echo "Usage: $0 \"message to agent\""
    exit 1
fi

TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
MESSAGE="$1"

mkdir -p state/inbox

TIMESTAMP_EPOCH=$(date +%s)

python3 -c "
import json, sys
msg = {
    'timestamp': '$TIMESTAMP',
    'type': 'operator_message',
    'text': json.loads(sys.stdin.read())
}
with open('state/inbox/msg_${TIMESTAMP_EPOCH}.json', 'w') as f:
    json.dump(msg, f)
" <<< "$MESSAGE"

echo "Operator message sent to agent. It will be picked up on next turn."
