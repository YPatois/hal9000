#!/bin/bash
# Send input to HAL9000 agent via the operator inbox.
# Usage: ./bin/attach "Your message"
set -euo pipefail
cd "$(dirname "$0")"/..

if [ $# -eq 0 ]; then
    echo "Usage: $0 \"message to agent\""
    exit 1
fi

TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
MESSAGE="$1"

echo "$TIMESTAMP" > /dev/null  # placeholder: write via docker exec
docker compose -f compose.yaml -p hal9000 exec -T hal9000 sh -c \
  "mkdir -p /state/inbox && cat > /state/inbox/msg_$(date +%s).json" <<EOF
{"timestamp": "$TIMESTAMP", "type": "operator_message", "text": $(echo -n "$MESSAGE" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')}
EOF

echo "Operator message sent to agent."
