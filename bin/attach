#!/bin/bash
# Send input to HAL9000 agent
# Usage: ./bin/attach "Your message"

cd "$(dirname "$0")"/..

if [ $# -eq 0 ]; then
    echo "Usage: $0 \"message to agent\""
    exit 1
fi

INPUT="$1"
DATE=$(date -u +%Y-%m-%d)
TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
mkdir -p logs/actions
echo "[$TIMESTAMP] [Operator] $INPUT" >> logs/actions/$DATE.log
echo "Message logged to operator channel"
