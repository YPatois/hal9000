#!/bin/bash
set -euo pipefail
cd "$(dirname "$0")"/..

for d in logs thoughts actions updates workspace state state/inbox; do
    mkdir -p "$d"
done

mkdir -p /tmp/hal9000

# Find Python and set up venv for the host daemon
PYTHON=""
for cmd in python3 python; do
    if command -v "$cmd" &>/dev/null; then
        PYTHON="$cmd"
        break
    fi
done
if [ -z "$PYTHON" ]; then
    echo "ERROR: No Python interpreter found (tried python3, python)" >&2
    exit 1
fi

HOST_VENV=".venv-host"
if [ ! -d "$HOST_VENV" ]; then
    echo "Creating host venv..."
    "$PYTHON" -m venv "$HOST_VENV"
fi
"$HOST_VENV/bin/pip" install -q httpx

# Kill any existing daemon before starting a new one
if [ -f state/host.pid ]; then
    OLD_PID=$(cat state/host.pid)
    kill "$OLD_PID" 2>/dev/null || true
    sleep 0.5
fi
# Also kill any stale daemon processes from earlier sessions
pkill -f "host\.daemon" 2>/dev/null || true
sleep 0.5

echo "Starting HAL9000 host daemon..."
HOST_PYTHON="$HOST_VENV/bin/python"
nohup "$HOST_PYTHON" -m host.daemon > /dev/null 2>&1 &
HOST_PID=$!
echo "$HOST_PID" > state/host.pid
echo "  Host daemon PID: $HOST_PID"

sleep 1

if ! kill -0 "$HOST_PID" 2>/dev/null; then
    echo "ERROR: Host daemon failed to start" >&2
    exit 1
fi

echo "Starting container..."
docker compose -f compose.yaml -p hal9000 build && docker compose -f compose.yaml -p hal9000 up -d

echo ""
echo "HAL9000 started."
echo "  Host daemon PID: $HOST_PID (stop with: kill $HOST_PID)"
echo "  View agent logs: docker compose -f compose.yaml -p hal9000 logs -f hal9000"
echo "  View daemon logs: tail -f logs/thoughts/$(date +%F).log"
echo "  Log viewer:      ./bin/view-logs  (opens http://localhost:8080)"
