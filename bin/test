#!/bin/bash
set -euo pipefail
cd "$(dirname "$0")"/..

VENV=".venv"
if [ ! -d "$VENV" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV"
fi

echo "Installing dependencies..."
"$VENV/bin/pip" install -q aiohttp httpx

echo
echo "=== Testing imports ==="
"$VENV/bin/python" << 'PYEOF'
import sys; sys.path.insert(0, '.')
from daemon.config import DaemonConfig
from daemon.log_record import LogRecord
from daemon.context_builder import ContextBuilder
from daemon.action_executor import ActionExecutor
from daemon.action_processor import ActionExtractor
print('All imports OK')
PYEOF

echo
echo "=== Testing action executor ==="
"$VENV/bin/python" << 'PYEOF'
import sys; sys.path.insert(0, '.')
from pathlib import Path
import tempfile, os
from daemon.action_executor import ActionExecutor

tmpdir = tempfile.mkdtemp()
e = ActionExecutor(Path(tmpdir), Path(tmpdir))

r = e.execute({'type': 'write', 'path': '/workspace/test.txt', 'content': 'hello'})
assert not r['success']  # no /workspace in tmpdir

r2 = e.execute({'type': 'write', 'path': '/state/test.txt', 'content': 'hello'})
assert not r2['success']

r3 = e.execute({'type': 'write', 'path': '/etc/passwd', 'content': 'evil'})
assert not r3['success'] and 'Blocked' in r3['error']

r4 = e.execute({'type': 'invalid', 'path': '/workspace/x'})
assert not r4['success'] and 'Unknown' in r4['error']

os.system('rm -rf ' + tmpdir)
print('Action executor OK')
PYEOF

echo
echo "=== Testing log record ==="
"$VENV/bin/python" << 'PYEOF'
import sys; sys.path.insert(0, '.')
from daemon.log_record import LogRecord

# no file I/O — purely in-memory ring buffer
l = LogRecord(max_history=50)

l.write_entry('thoughts', {'type': 'test', 'text': 'hello'})
l.write_entry('thoughts', {'type': 'test', 'text': 'world'})

recent = l.recent_entries(10, ['thoughts'])
assert len(recent) == 2
assert recent[0]['text'] == 'hello'
assert recent[-1]['text'] == 'world'

# default when no matching categories
empty = l.recent_entries(10, ['actions'])
assert len(empty) == 0

# category is automatically added
assert recent[0]['category'] == 'thoughts'

print('Log record OK')
PYEOF

echo
echo "=== Testing context builder ==="
"$VENV/bin/python" << 'PYEOF'
import sys; sys.path.insert(0, '.')
from daemon.context_builder import ContextBuilder

c = ContextBuilder('You are an agent.')
ctx = c.build({}, [])
assert len(ctx) > 30

ctx2 = c.build({'last_summary': 'my state'}, [])
assert 'my state' in ctx2

print('Context builder OK')
PYEOF

echo
echo "=== Testing action processor ==="
"$VENV/bin/python" << 'PYEOF'
import sys; sys.path.insert(0, '.')
from daemon.action_processor import ActionExtractor

e = ActionExtractor()
text, actions = e.parse_response(
    'Hello\n\n```action\n{"type": "write", "path": "/workspace/x"}\n```'
)
assert len(actions) == 1
assert actions[0]['type'] == 'write'

text2, actions2 = e.parse_response('No action here')
assert len(actions2) == 0
print('Action processor OK')
PYEOF

echo
echo "=== All tests passed. ==="
